{
  "version": 1,
  "hooks": {
    "sessionStart": [
      {
        "type": "command",
        "bash": ".github/hooks/scripts/session-init.sh",
        "powershell": ".github/hooks/scripts/session-init.ps1",
        "timeoutSec": 30
      }
    ],
    "sessionEnd": [
      {
        "type": "command",
        "bash": ".github/hooks/scripts/session-cleanup.sh",
        "powershell": ".github/hooks/scripts/session-cleanup.ps1",
        "timeoutSec": 30
      }
    ],
    "userPromptSubmitted": [
      {
        "type": "command",
        "bash": ".github/hooks/scripts/log-prompt.sh",
        "powershell": ".github/hooks/scripts/log-prompt.ps1",
        "timeoutSec": 10
      }
    ],
    "preToolUse": [
      {
        "type": "command",
        "bash": ".github/hooks/scripts/security-gate.sh",
        "powershell": ".github/hooks/scripts/security-gate.ps1",
        "timeoutSec": 15
      }
    ],
    "postToolUse": [
      {
        "type": "command",
        "bash": ".github/hooks/scripts/lint-on-edit.sh",
        "powershell": ".github/hooks/scripts/lint-on-edit.ps1",
        "timeoutSec": 60
      }
    ],
    "agentStop": [
      {
        "type": "command",
        "bash": ".github/hooks/scripts/post-session-report.sh",
        "powershell": ".github/hooks/scripts/post-session-report.ps1",
        "timeoutSec": 30
      }
    ],
    "subagentStop": [
      {
        "type": "command",
        "bash": ".github/hooks/scripts/validate-subagent-output.sh",
        "powershell": ".github/hooks/scripts/validate-subagent-output.ps1",
        "timeoutSec": 15
      }
    ],
    "errorOccurred": [
      {
        "type": "command",
        "bash": ".github/hooks/scripts/error-reporter.sh",
        "powershell": ".github/hooks/scripts/error-reporter.ps1",
        "timeoutSec": 10
      }
    ]
  }
}
