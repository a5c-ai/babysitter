{
  "name": "@a5c-ai/babysitter-genty",
  "version": "5.1.0",
  "description": "Babysitter orchestration provider for genty — bridges genty's framework-agnostic interfaces to the babysitter-sdk runtime",
  "license": "MIT",
  "type": "commonjs",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": { "types": "./dist/index.d.ts", "require": "./dist/index.js", "default": "./dist/index.js" },
    "./register": { "types": "./dist/register.d.ts", "require": "./dist/register.js", "default": "./dist/register.js" }
  },
  "files": ["dist/", "README.md"],
  "publishConfig": { "access": "public" },
  "scripts": {
    "build": "tsc --build tsconfig.json",
    "clean": "rimraf dist tsconfig.tsbuildinfo",
    "test": "vitest run"
  },
  "dependencies": {
    "@a5c-ai/babysitter-sdk": "5.1.0",
    "@a5c-ai/genty-platform": "5.1.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.30",
    "rimraf": "^6.1.3",
    "typescript": "^5.4.2",
    "vitest": "^4.0.18"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/a5c-ai/babysitter.git",
    "directory": "packages/babysitter-genty"
  },
  "homepage": "https://github.com/a5c-ai/babysitter/tree/main/packages/babysitter-genty#readme",
  "bugs": {
    "url": "https://github.com/a5c-ai/babysitter/issues"
  },
  "keywords": [
    "babysitter",
    "genty",
    "orchestration",
    "provider",
    "plugin"
  ]
}
