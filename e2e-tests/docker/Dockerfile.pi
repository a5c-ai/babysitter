FROM node:20-bookworm

RUN apt-get update && apt-get install -y \
    bash \
    git \
    jq \
    ca-certificates \
    && rm -rf /var/lib/apt/lists/*

RUN groupadd -r pi && useradd -r -g pi -m -d /home/pi pi

ENV HOME=/home/pi
ENV PATH=/home/pi/.local/bin:${PATH}

RUN mkdir -p /home/pi/.local && \
    echo "prefix=/home/pi/.local" > /home/pi/.npmrc

WORKDIR /app

COPY package.json package-lock.json* ./
COPY packages/sdk/package.json ./packages/sdk/
COPY packages/agent-catalog/package.json ./packages/agent-catalog/
COPY packages/agent-plugins-mux/package.json ./packages/agent-plugins-mux/
COPY third_party/webpackbar ./third_party/webpackbar

RUN npm install --include=dev

COPY . .

RUN npm run build:sdk && \
    npm run build --workspace=@a5c-ai/agent-catalog && \
    npm run build --workspace=@a5c-ai/agent-plugins-mux && \
    node /app/packages/agent-plugins-mux/dist/cli.js compile --target pi --source /app/plugins/babysitter-unified --output /app/plugins/babysitter-pi --verify && \
    chown -R pi:pi /app /home/pi

USER pi

RUN npm install -g @mariozechner/pi-coding-agent /app/packages/sdk /app/plugins/babysitter-pi

WORKDIR /workspace

ENV A5C_PROVIDER_NAME=""
ENV A5C_SELECTED_CLI_COMMAND=""
ENV A5C_CLI_TOOL=""
ENV A5C_SELECTED_MODEL=""

CMD ["bash"]
