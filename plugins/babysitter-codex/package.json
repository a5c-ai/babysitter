{
  "name": "@a5c-ai/babysitter-codex",
  "version": "0.1.5",
  "description": "Babysitter Codex skill bundle and integration package for OpenAI Codex CLI with SDK-managed process-library bootstrapping, 15 orchestration modes, and BOM-safe SKILL installation",
  "scripts": {
    "test": "node test/integration.test.js && node test/harness.test.js && node test/plugin.test.js && node test/packaged-install.test.js && node test/features-1-10.test.js",
    "test:unit": "node test/harness.test.js",
    "test:integration": "node test/integration.test.js",
    "test:plugin": "node test/plugin.test.js",
    "test:features": "node test/features-1-10.test.js",
    "test:scenario": "node test/full-session-scenario.js",
    "test:long-scenario": "node test/full-session-long-run.js",
    "check:mapping": "node scripts/check-mapping-contract.js",
    "team:install": "node scripts/team-install.js",
    "lint": "find .codex -name '*.js' | xargs -I{} node --check {}",
    "deploy": "npm publish --access public",
    "deploy:staging": "npm publish --access public --tag staging",
    "postinstall": "node bin/postinstall.js",
    "preuninstall": "node bin/uninstall.js"
  },
  "files": [
    "SKILL.md",
    "AGENTS.md",
    "CHANGELOG.md",
    "agents/",
    "commands/",
    ".codex/",
    "bin/",
    "scripts/",
    "test/",
    "babysitter.lock.json",
    "README.md"
  ],
  "keywords": [
    "babysitter",
    "codex",
    "orchestration",
    "ai-agent",
    "sdk-integration",
    "codex-skill"
  ],
  "author": "a5c.ai",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/a5c-ai/babysitter"
  },
  "homepage": "https://github.com/a5c-ai/babysitter/tree/main/plugins/babysitter-codex#readme",
  "dependencies": {
    "@a5c-ai/babysitter-sdk": "^0.0.173"
  }
}
