{
  "version": 1,
  "hooks": {
    "sessionStart": [
      {
        "type": "command",
        "bash": "npx -y @a5c-ai/hooks-proxy-cli invoke --adapter copilot --handler \"bash ./hooks/babysitter-proxied-session-start.sh\" --json",
        "powershell": "npx -y @a5c-ai/hooks-proxy-cli invoke --adapter copilot --handler \"bash ./hooks/babysitter-proxied-session-start.sh\" --json",
        "timeoutSec": 30
      }
    ],
    "userPromptSubmitted": [
      {
        "type": "command",
        "bash": "npx -y @a5c-ai/hooks-proxy-cli invoke --adapter copilot --handler \"bash ./hooks/babysitter-proxied-user-prompt-submitted.sh\" --json",
        "powershell": "npx -y @a5c-ai/hooks-proxy-cli invoke --adapter copilot --handler \"bash ./hooks/babysitter-proxied-user-prompt-submitted.sh\" --json",
        "timeoutSec": 15
      }
    ],
    "sessionEnd": [
      {
        "type": "command",
        "bash": "npx -y @a5c-ai/hooks-proxy-cli invoke --adapter copilot --handler \"bash ./hooks/babysitter-proxied-session-end.sh\" --json",
        "powershell": "npx -y @a5c-ai/hooks-proxy-cli invoke --adapter copilot --handler \"bash ./hooks/babysitter-proxied-session-end.sh\" --json",
        "timeoutSec": 30
      }
    ]
  }
}
