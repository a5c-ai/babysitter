{
  "name": "@a5c-ai/babysitter-pi",
  "version": "0.1.0",
  "type": "module",
  "description": "Babysitter PI-family plugin bundle with explicit installer commands for pi and oh-my-pi plugin roots",
  "keywords": ["pi-package", "omp", "babysitter", "orchestration", "ai-agent"],
  "omp": {
    "extensions": ["./extensions"],
    "skills": ["./skills"]
  },
  "dependencies": {
    "@a5c-ai/babysitter-sdk": "^0.0.180"
  },
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": "*"
  },
  "scripts": {
    "test": "node --test test/integration.test.js && npx tsx --test test/harness.test.js && npx tsx --test test/tui.test.js",
    "sync:commands": "node scripts/sync-command-docs.cjs",
    "test:integration": "node --test test/integration.test.js",
    "test:harness": "npx tsx --test test/harness.test.js",
    "test:tui": "npx tsx --test test/tui.test.js",
    "deploy": "npm publish --access public",
    "deploy:staging": "npm publish --access public --tag staging"
  },
  "bin": {
    "babysitter-pi": "bin/cli.cjs"
  },
  "files": [
    "bin/",
    "package.json",
    "extensions/",
    "skills/",
    "commands/",
    "scripts/"
  ],
  "author": "a5c.ai",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/a5c-ai/babysitter"
  },
  "homepage": "https://github.com/a5c-ai/babysitter/tree/main/plugins/babysitter-pi#readme"
}
