{
  "version": 1,
  "hooks": {
    "sessionStart": [
      {
        "type": "command",
        "bash": "npx -y @a5c-ai/hooks-proxy-cli invoke --adapter cursor --handler \"bash ./hooks/babysitter-proxied-session-start.sh\" --json",
        "powershell": "npx -y @a5c-ai/hooks-proxy-cli invoke --adapter cursor --handler \"bash ./hooks/babysitter-proxied-session-start.sh\" --json",
        "timeoutSec": 30
      }
    ],
    "stop": [
      {
        "type": "command",
        "bash": "npx -y @a5c-ai/hooks-proxy-cli invoke --adapter cursor --handler \"bash ./hooks/babysitter-proxied-stop.sh\" --json",
        "powershell": "npx -y @a5c-ai/hooks-proxy-cli invoke --adapter cursor --handler \"bash ./hooks/babysitter-proxied-stop.sh\" --json",
        "loop_limit": null
      }
    ]
  }
}
