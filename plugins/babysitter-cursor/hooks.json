{
  "version": 1,
  "hooks": {
    "sessionStart": [
      {
        "type": "command",
        "bash": "./hooks/session-start.sh",
        "powershell": "./hooks/session-start.ps1",
        "timeoutSec": 30
      }
    ],
    "stop": [
      {
        "type": "command",
        "bash": "./hooks/stop-hook.sh",
        "powershell": "./hooks/stop-hook.ps1",
        "loop_limit": null
      }
    ]
  }
}
